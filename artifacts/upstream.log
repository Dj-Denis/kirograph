-const KIROGRAPH_DIR = join(homedir(), '.kirograph');
-const MODELS_DIR = join(KIROGRAPH_DIR, 'models');
-const MODEL_ID = 'nomic-ai/nomic-embed-text-v1.5';
-
-async function downloadModel() {
-  // Ensure directories exist
