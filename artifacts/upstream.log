+            .sort();
+          if (files.length > 0) {
+            lines.push('', `Files (${files.length}):`);
+            for (const f of files.slice(0, 30)) lines.push(`  ${f}`);
+            if (files.length > 30) lines.push(`  …and ${files.length - 30} more`);
+          }
+        }
+
+        return lines.join('\n');
+      }
+
       default:
         return `Unknown tool: ${toolName}`;
     }
